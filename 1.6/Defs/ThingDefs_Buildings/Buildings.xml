<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <ThingDef ParentName="BuildingBase">
        <defName>MN_NetworkCable</defName>
        <label>network cable</label>
        <description>A bundle of network cables for moving data around. Can be placed under walls and other buildings.</description>
        <thingClass>SK_Matter_Network.NetworkBuilding</thingClass>
        <category>Building</category>
        <noRightClickDraftAttack>true</noRightClickDraftAttack>
        <graphicData>
            <texPath>Things/Building/Linked/PowerConduit_Atlas</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <linkType>Transmitter</linkType>
            <linkFlags>
                <li>PowerConduit</li>
            </linkFlags>
            <damageData>
                <rect>(0,0.35,1,0.3)</rect>
            </damageData>
            <color>(0,0,0,0)</color>
            <shaderType>Transparent</shaderType>
        </graphicData>
        <uiIconPath>Things/Building/Linked/PowerConduit_MenuIcon</uiIconPath>
        <uiIconScale>0.7</uiIconScale>
        <building>
            <isPowerConduit>false</isPowerConduit>
            <ai_chillDestination>false</ai_chillDestination>
            <isInert>true</isInert>
            <isEdifice>false</isEdifice>
            <canLandGravshipOn>true</canLandGravshipOn>
            <blueprintGraphicData>
                <texPath>Things/Building/Linked/PowerConduit_Blueprint_Atlas</texPath>
            </blueprintGraphicData>
            <canConstructInCorner>true</canConstructInCorner>
            <ai_neverTrashThis>true</ai_neverTrashThis>
            <isTargetable>false</isTargetable>
            <expandHomeArea>false</expandHomeArea>
            <canBeDamagedByAttacks>false</canBeDamagedByAttacks>
        </building>
        <drawerType>MapMeshOnly</drawerType>
        <altitudeLayer>Conduits</altitudeLayer>
        <passability>Standable</passability>
        <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
        <resourcesFractionWhenDeconstructed>0</resourcesFractionWhenDeconstructed>
        <statBases>
            <MaxHitPoints>100</MaxHitPoints>
            <WorkToBuild>100</WorkToBuild>
            <Flammability>0</Flammability>
            <Beauty>-2</Beauty>
        </statBases>
        <drawStyleCategory>Conduits</drawStyleCategory>
        <costList>
            <Steel>4</Steel>
        </costList>
        <placeWorkers>
            <li>PlaceWorker_Conduit</li>
            <li>SK_Matter_Network.PlaceWorker_OneControllerPerNetwork</li>
            <li>PlaceWorker_InvalidOverSubstructure</li>
        </placeWorkers>
        <rotatable>false</rotatable>
        <selectable>true</selectable>
        <neverMultiSelect>true</neverMultiSelect>
        <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
        <researchPrerequisites>
            <li>MN_MatterNetwork</li>
        </researchPrerequisites>
        <designationCategory>Misc</designationCategory>
        <uiOrder>2000</uiOrder>
        <constructEffect>ConstructMetal</constructEffect>
        <clearBuildingArea>false</clearBuildingArea>
        <replaceTags>
            <li>Conduit</li>
        </replaceTags>
    </ThingDef>

    <ThingDef ParentName="BuildingBase">
        <defName>MN_DiskDrive</defName>
        <label>disk drive</label>
        <description>Holds matter disks that provide storage capacity to a connected data network. Can hold up to 6 disks. Add more drives or larger disks to increase how much the network can store.</description>
        <graphicData>
            <texPath>Things/Building/SpacerProps/ServerRack/ServerRack</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(1.5,1.5)</drawSize>
            <shaderType>CutoutComplex</shaderType>
            <shadowData>
                <volume>(0.55, 0.30, 0.40)</volume>
            </shadowData>
        </graphicData>
        <category>Building</category>
        <statBases>
            <MaxHitPoints>300</MaxHitPoints>
            <WorkToBuild>1000</WorkToBuild>
            <Flammability>0.5</Flammability>
            <Beauty>-1</Beauty>
        </statBases>
        <thingClass>SK_Matter_Network.NetworkBuildingDiskDrive</thingClass>
        <costList>
            <Steel>200</Steel>
            <ComponentIndustrial>2</ComponentIndustrial>
        </costList>
        <building>
            <storageGroupTag>DiskDrive</storageGroupTag>
            <fixedStorageSettings>
                <filter>
                    <thingDefs>
                        <li>MN_Disk1k</li>
                        <li>MN_Disk2k</li>
                        <li>MN_Disk4k</li>
                        <li>MN_Disk8k</li>
                    </thingDefs>
                </filter>
            </fixedStorageSettings>
            <defaultStorageSettings>
                <priority>Preferred</priority>
                <filter>
                    <thingDefs>
                        <li>MN_Disk1k</li>
                        <li>MN_Disk2k</li>
                        <li>MN_Disk4k</li>
                        <li>MN_Disk8k</li>
                    </thingDefs>
                </filter>
            </defaultStorageSettings>
            <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
            <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
            <maxItemsInCell>6</maxItemsInCell>
            <blueprintClass>Blueprint_Storage</blueprintClass>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <fillPercent>0.4</fillPercent>
        <pathCost>50</pathCost>
        <inspectorTabs>
            <li>ITab_Storage</li>
        </inspectorTabs>
        <surfaceType>None</surfaceType>
        <canOverlapZones>false</canOverlapZones>
        <placeWorkers>
            <li>SK_Matter_Network.PlaceWorker_OneControllerPerNetwork</li>
            <li>PlaceWorker_InvalidOverSubstructure</li>
        </placeWorkers>
        <researchPrerequisites>
            <li>MN_MatterNetwork</li>
        </researchPrerequisites>
        <uiOrder>2050</uiOrder>
        <designationCategory>Misc</designationCategory>
        <preventDroppingThingsOn>true</preventDroppingThingsOn>
        <defaultPlacingRot>South</defaultPlacingRot>
        <uiIconScale>0.8</uiIconScale>
    </ThingDef>

    <ThingDef ParentName="BuildingBase">
        <defName>MN_NetworkInterface</defName>
        <label>network interface</label>
        <description>A storage access point for a data network. Pawns can upload and extract allowed items here when the network has an active controller, and the selected storage filter is shared across the network.</description>
        <graphicData>
            <texPath>Things/Building/SpacerProps/SingleDisplay/SingleDisplay</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(1.2,1.2)</drawSize>
            <shaderType>CutoutComplex</shaderType>
            <shadowData>
                <volume>(0.3, 0.30, 0.40)</volume>
            </shadowData>
        </graphicData>
        <category>Building</category>
        <noRightClickDraftAttack>true</noRightClickDraftAttack>
        <statBases>
            <MaxHitPoints>200</MaxHitPoints>
            <WorkToBuild>500</WorkToBuild>
            <StyleDominance MayRequire="Ludeon.RimWorld.Ideology">5</StyleDominance>
            <Flammability>0.5</Flammability>
            <Beauty>-1</Beauty>
        </statBases>
        <thingClass>SK_Matter_Network.NetworkBuildingNetworkInterface</thingClass>
        <costList>
            <Steel>400</Steel>
            <ComponentSpacer>2</ComponentSpacer>
            <Plasteel>50</Plasteel>
        </costList>
        <building>
            <fixedStorageSettings>
                <filter>
                    <categories>
                        <li>Root</li>
                    </categories>
                    <disallowedCategories>
                        <li>Corpses</li>
                        <li>Animals</li>
                    </disallowedCategories>
                    <disallowedThingDefs>
                        <li>MN_Disk1k</li>
                        <li>MN_Disk2k</li>
                        <li>MN_Disk4k</li>
                        <li>MN_Disk8k</li>
                    </disallowedThingDefs>
                </filter>
            </fixedStorageSettings>
            <defaultStorageSettings>
                <priority>Preferred</priority>
                <filter>
                    <categories>
                        <li>Foods</li>
                        <li>Manufactured</li>
                        <li>ResourcesRaw</li>
                        <li>Items</li>
                        <li>Weapons</li>
                        <li>Apparel</li>
                        <li>BodyParts</li>
                    </categories>
                </filter>
            </defaultStorageSettings>
            <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
            <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
            <maxItemsInCell>500</maxItemsInCell>
            <blueprintClass>Blueprint_Storage</blueprintClass>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <fillPercent>0.4</fillPercent>
        <pathCost>50</pathCost>
        <inspectorTabs>
            <li>ITab_Storage</li>
            <li>SK_Matter_Network.ITab_NetworkStorage</li>
        </inspectorTabs>
        <surfaceType>None</surfaceType>
        <canOverlapZones>false</canOverlapZones>
        <placeWorkers>
            <li>SK_Matter_Network.PlaceWorker_OneControllerPerNetwork</li>
            <li>PlaceWorker_InvalidOverSubstructure</li>
        </placeWorkers>
        <researchPrerequisites>
            <li>MN_MatterNetwork</li>
        </researchPrerequisites>
        <uiOrder>2050</uiOrder>
        <designationCategory>Misc</designationCategory>
        <preventDroppingThingsOn>true</preventDroppingThingsOn>
        <hasInteractionCell>true</hasInteractionCell>
        <interactionCellOffset>(0,0,1)</interactionCellOffset>
        <defaultPlacingRot>South</defaultPlacingRot>
        <uiIconScale>0.8</uiIconScale>
    </ThingDef>

    <ThingDef ParentName="BuildingBase">
        <defName>MN_NetworkController</defName>
        <label>network controller</label>
        <description>The central hub of a data network. Stores all items digitally. A network can have only one active controller.</description>
        <thingClass>SK_Matter_Network.NetworkBuildingController</thingClass>
        <graphicData>
            <texPath>Things/Building/SpacerProps/PersonalConsole/PersonalConsole</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(1.5,1.5)</drawSize>
            <shaderType>CutoutComplex</shaderType>
            <shadowData>
                <volume>(0.55, 0.30, 0.40)</volume>
            </shadowData>
        </graphicData>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <fillPercent>0.2</fillPercent>
        <statBases>
            <MaxHitPoints>400</MaxHitPoints>
            <WorkToBuild>2000</WorkToBuild>
            <Flammability>0.5</Flammability>
        </statBases>
        <size>(1,1)</size>
        <costList>
            <Steel>500</Steel>
            <ComponentSpacer>4</ComponentSpacer>
            <Plasteel>50</Plasteel>
            <Gold>20</Gold>
        </costList>
        <building>
            <fixedStorageSettings>
                <filter>
                    <categories>
                        <li>Root</li>
                    </categories>
                    <disallowedThingDefs>
                        <li>MN_Disk1k</li>
                        <li>MN_Disk2k</li>
                        <li>MN_Disk4k</li>
                        <li>MN_Disk8k</li>
                    </disallowedThingDefs>
                </filter>
            </fixedStorageSettings>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <placeWorkers>
            <li>SK_Matter_Network.PlaceWorker_OneControllerPerNetwork</li>
            <li>PlaceWorker_InvalidOverSubstructure</li>
        </placeWorkers>
        <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
        <researchPrerequisites>
            <li>MN_MatterNetwork</li>
        </researchPrerequisites>
        <designationCategory>Misc</designationCategory>
        <defaultPlacingRot>South</defaultPlacingRot>
        <uiIconScale>1</uiIconScale>
    </ThingDef>
</Defs>
