        </recipeMaker>
        <costList>
            <Steel>100</Steel>
            <ComponentIndustrial>2</ComponentIndustrial>
            <Gold>10</Gold>
        </costList>
    </ThingDef>

    <ThingDef ParentName="DiskBase">
        <defName>MN_Disk4k</defName>
        <graphicData>
            <texPath>MatterNetwork/Things/Item/disk_4k</texPath>
